FROM scratch AS ctx
COPY ../shared/ /shared

FROM ghcr.io/archlinux/archlinux:latest as hyperion-ci

LABEL usage="This image is a distrobox image designed for gaming with steam, heroic, and more." \
      summary="Gaming Ready Arch Container with Chaotic AUR & Optimisations" \
      maintainer="tj5miniop@gmail.com"


# We copy the pacman.conf early
COPY ./files/pacman.conf /etc/pacman.conf
COPY ./files/pacman.conf.chaotic /tmp/pacman.conf.chaotic

# 2. Fix ALPM Sandboxing & Setup User
RUN sed -i 's/#Color/Color/g' /etc/pacman.conf && \
    sed -i 's/#MAKEFLAGS="-j2"/MAKEFLAGS="-j$(nproc)"/g' /etc/makepkg.conf && \
    pacman-key --init && pacman-key --populate && \
    pacman -Syu --noconfirm --disable-sandbox && \
    useradd -m -G --shell=/bin/bash build wheel && \
    pacman -S --noconfirm --needed base-devel git sudo --disable-sandbox

# Setup
USER build
WORKDIR /tmp


# CHAOTIC-AUR setup 
RUN sudo pacman-key --recv-key 3056513887B78AEB --keyserver keyserver.ubuntu.com && \
    sudo pacman-key --lsign-key 3056513887B78AEB && \
    sudo pacman -U --noconfirm --disable-sandbox \
        'https://cdn-mirror.chaotic.cx/chaotic-aur/chaotic-keyring.pkg.tar.zst' \
        'https://cdn-mirror.chaotic.cx/chaotic-aur/chaotic-mirrorlist.pkg.tar.zst' && \
    sudo cp /tmp/pacman.conf.chaotic /etc/pacman.conf && \
    sudo pacman -Syyu --noconfirm --disable-sandbox

# Package Installation - NOTE - this installs the xdg-desktop-portal-kde, this will be removed from all NON-KDE desktop releases of hyperion.
# NOTE - this is a standard arch install, just tweaked so you can just install whatever you want 
RUN sudo pacman -S --noconfirm --needed --disable-sandbox \
    jupiter-main/gamescope steam xdg-desktop-portal xdg-desktop-portal-kde \
    xdg-desktop-portal-gamescope vulkan-intel intel-media-driver vulkan-radeon vulkan-headers \
    lib32-vulkan-radeon lib32-vulkan-intel mangohud scx-scheds scx-tools \
    noto-fonts ttf-dejavu ttf-liberation noto-fonts-emoji noto-fonts-cjk \
    flac ffmpeg wavpack lame libmad faac libwebp libavif libheif libjxl aom libde265 x264 \
    heroic-games-launcher-bin faugus-launcher \
    protonplus bottles yay \
    fish micro fastfetch distrobox podman

# AUR Packages (yay)
RUN yay -S --noconfirm scopebuddy scopebuddy-gui-git goverlay-git && \
    yay -Scc --noconfirm

# Cleanup
USER root
RUN userdel -r build && \
    rm -rf /tmp/* /var/cache/pacman/pkg/*

WORKDIR /
